# =============================================================================
# EMAIL PHISHING SCANNER - Environment Configuration Template
# =============================================================================
# Salin file ini ke .env dan isi nilai asli
# JANGAN isi dengan nilai production di file ini!
# =============================================================================

# Application Settings
APP_ENV=development
API_V1_STR=/api/v1
PROJECT_NAME=Email Phishing Scanner

# Security & External API Keys (WAJIB diisi!)
GOOGLE_SAFE_BROWSING_API_KEY=your_google_api_key_here
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
SECRET_KEY=generate_random_32_char_string_here

# URL Threat Detection Provider
URL_THREAT_PROVIDER=google_safe_browsing

# Rate Limiting
RATE_LIMIT=5/minute
REDIS_URL=

# DNS Settings
DNS_TIMEOUT=10.0
DNS_NAMESERVERS=8.8.8.8,8.8.4.4,1.1.1.1,1.0.0.1

# Database
DATABASE_URL=sqlite:///./backend/data/scan_history.db
HISTORY_RETENTION_DAYS=30

# Production Settings (Optional)
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000
LOG_LEVEL=info
ENABLE_DOCS=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Monitoring (Optional)
ADMIN_EMAIL=security@company.com
MONITORING_WEBHOOK_URL=
ALERT_RISK_SCORE_THRESHOLD=90